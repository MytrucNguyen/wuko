{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm validate:registry && pnpm generate:registry-static",
    "dev": "next dev",
    "prebuild": "pnpm validate:registry && pnpm generate:registry-static",
    "build": "next build && pagefind --site out --output-path out/_pagefind",
    "postbuild": "pnpm sync:pagefind-dev",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "validate:registry": "tsx scripts/validate-registry.ts",
    "generate:registry-static": "tsx scripts/generate-registry-static.ts",
    "sync:pagefind-dev": "tsx scripts/sync-pagefind-dev.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.3.6",
    "@storybook/nextjs-vite": "10.3.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pagefind": "1.5.2",
    "storybook": "10.3.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "8.0.10"
  }
}
